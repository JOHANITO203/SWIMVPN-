# Backend local environment template (source-of-truth aligned)

NODE_ENV=development
LOG_LEVEL=info

PORT=3000
DATABASE_URL=postgresql://swim_user:swim_password@localhost:5432/swimvpn_db?schema=public

# Internal service hosts for local/dev docker
CUSTOMER_SERVICE_HOST=127.0.0.1
INVENTORY_SERVICE_HOST=127.0.0.1
ADMIN_SERVICE_HOST=127.0.0.1
VPN_CONFIG_SERVICE_HOST=127.0.0.1
STORE_SERVICE_HOST=127.0.0.1

JWT_SECRET=change_this_jwt_secret

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
ADMIN_CHAT_ID=your_admin_chat_id

DEFAULT_CURRENCY=RUB

