# Backend local environment template (source-of-truth aligned)

NODE_ENV=development
LOG_LEVEL=info

PORT=3000
POSTGRES_USER=swim_user
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_DB=swimvpn_db
DATABASE_URL=postgresql://swim_user:swim_password@localhost:5432/swimvpn_db?schema=public

# Internal service hosts for local/dev docker
CUSTOMER_SERVICE_HOST=127.0.0.1
INVENTORY_SERVICE_HOST=127.0.0.1
ADMIN_SERVICE_HOST=127.0.0.1
VPN_CONFIG_SERVICE_HOST=127.0.0.1
STORE_SERVICE_HOST=127.0.0.1
NOTIFICATION_SERVICE_HOST=127.0.0.1

JWT_SECRET=change_this_jwt_secret
ADMIN_JWT_SECRET=change_this_admin_jwt_secret

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
NOTIFICATION_BOT_TOKEN=
ADMIN_CHAT_ID=your_admin_chat_id

ADMIN_SUPPORT_BOT_TOKEN=your_admin_support_bot_token
ADMIN_SUPPORT_CHAT_ID=-1003912107958
ADMIN_SUPPORT_REPORT_CHAT_ID=
ADMIN_SUPPORT_DEFAULT_LANGUAGE=ru
ADMIN_SUPPORT_FALLBACK_LANGUAGE=en

RESEND_API_KEY=change_this_resend_api_key
MAILER_FROM_EMAIL=support@swimvpn.pro
MAILER_FROM_NAME=SWIMVPN+ Support

DEFAULT_CURRENCY=RUB

# Deferred in MVP (documented only)
# PAYMENT_PROVIDER_SHOP_ID=
# PAYMENT_PROVIDER_SECRET_KEY=
