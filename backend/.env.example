# Backend local environment template (source-of-truth aligned)

NODE_ENV=development
LOG_LEVEL=info

PORT=3000
POSTGRES_USER=swim_user
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_DB=swimvpn_db
DATABASE_URL=postgresql://swim_user:change_this_postgres_password@localhost:5432/swimvpn_db?schema=public
PRISMA_VALIDATE_SCHEMA=true

# Seed policy
# Default seed is production-safe: creates missing reference plans/servers only.
# Set SEED_DEMO_DATA=true only in disposable local/dev databases to create starter inventory.
SEED_DEMO_DATA=false

# Internal service hosts for local/dev docker
CUSTOMER_SERVICE_HOST=127.0.0.1
INVENTORY_SERVICE_HOST=127.0.0.1
ADMIN_SERVICE_HOST=127.0.0.1
VPN_CONFIG_SERVICE_HOST=127.0.0.1
STORE_SERVICE_HOST=127.0.0.1
NOTIFICATION_SERVICE_HOST=127.0.0.1

JWT_SECRET=change_this_jwt_secret
ADMIN_JWT_SECRET=change_this_admin_jwt_secret

# Admin bootstrap
# No default database admin is created by prisma/seed.ts.
# Create the first Admin row through a controlled ops step with a bcrypt password_hash.
# Telegram admin operations must use explicit ADMIN_USER_IDS.

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
NOTIFICATION_BOT_TOKEN=
ADMIN_CHAT_ID=your_admin_chat_id
# Comma-separated Telegram user ids allowed to use private admin commands.
# Send /whoami to the admin/payment bot to retrieve your User id.
ADMIN_USER_IDS=
PAYMENT_BOT_TOKEN=
PAYMENT_BOT_USERNAME=your_payment_bot_username
PAYMENT_REVIEW_CHAT_ID=
MANUAL_CARD_NUMBER=

ADMIN_SUPPORT_BOT_TOKEN=your_admin_support_bot_token
ADMIN_SUPPORT_CHAT_ID=-1003912107958
ADMIN_SUPPORT_REPORT_CHAT_ID=
ADMIN_SUPPORT_DEFAULT_LANGUAGE=ru
ADMIN_SUPPORT_FALLBACK_LANGUAGE=en

RESEND_API_KEY=change_this_resend_api_key
MAILER_FROM_EMAIL=support@swimvpn.pro
MAILER_FROM_NAME=SWIMVPN+ Support

DEFAULT_CURRENCY=RUB
CRYPTO_PAY_API_TOKEN=
CRYPTO_PAY_API_BASE_URL=https://pay.crypt.bot/api
CRYPTO_PAY_ACCEPTED_ASSETS=USDT,TON,BTC,ETH,TRX,LTC,BNB,USDC
CRYPTO_PAY_INVOICE_EXPIRES_IN=1800

# 32-byte AES key encoded as base64/base64url for swimvpn://crypt1 generation.
# Generate locally with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SWIMVPN_CRYPT1_KEY_BASE64=

# Deferred in MVP (documented only)
# PAYMENT_PROVIDER_SHOP_ID=
# PAYMENT_PROVIDER_SECRET_KEY=
