# Configuration de la base de données
DATABASE_URL="postgresql://swim_user:swim_password@localhost:5432/swimvpn_db?schema=public"

# Port de l'application
PORT=3000

# Variables pour l'intégration de paiement (ex: YooKassa)
PAYMENT_PROVIDER_SHOP_ID="your_shop_id"
PAYMENT_PROVIDER_SECRET_KEY="your_secret_key"

# Variables pour l'email
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="no-reply@swimvpn.com"
SMTP_PASS="your_password"
