# ============================================
# SWIMVPN+ DOCKER DEPLOYMENT ENVIRONMENT
# ============================================
# Copy this file to .env and fill in the values
# For production, use secure passwords and secrets

# ====================
# DEPLOYMENT SETTINGS
# ====================
NODE_ENV=production
LOG_LEVEL=info

# ====================
# DATABASE SETTINGS
# ====================
POSTGRES_USER=swim_user
POSTGRES_PASSWORD=change_this_to_strong_password
POSTGRES_DB=swimvpn_db
POSTGRES_PORT=5432

# ====================
# REDIS SETTINGS
# ====================
REDIS_PASSWORD=change_this_to_strong_redis_password
REDIS_PORT=6379

# ====================
# JWT & SECURITY
# ====================
JWT_SECRET=generate_a_secure_random_string_minimum_32_chars
ADMIN_JWT_SECRET=generate_another_secure_random_string_for_admin

# ====================
# TELEGRAM BOT INTEGRATION
# ====================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_CHAT_ID=your_admin_chat_id_here

# ====================
# SERVICE PORTS
# ====================
GATEWAY_PORT=3000
PGADMIN_PORT=8080

# ====================
# PGADMIN SETTINGS (Optional)
# ====================
PGADMIN_EMAIL=admin@swimvpn.com
PGADMIN_PASSWORD=admin_password

# ====================
# VPN CONFIG ENGINE SETTINGS
# ====================
CONFIG_VALIDATION_STRICT=true
MAX_CONFIG_SIZE_KB=1024

# ====================
# BUSINESS SETTINGS
# ====================
DEFAULT_CURRENCY=RUB

# ====================
# DOCKER RESOURCE LIMITS
# ====================
# Uncomment and adjust as needed
# DOCKER_MEMORY_LIMIT=512M
# DOCKER_CPU_LIMIT=0.5