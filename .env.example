# SWIMVPN+ production environment
# Copy to .env and set real values before deploy

NODE_ENV=production
LOG_LEVEL=info

# Domain / ACME
TRAEFIK_ACME_EMAIL=ops@swimvpn.pro
TRAEFIK_DASHBOARD_AUTH=admin:$apr1$replace_with_htpasswd_hash

# PostgreSQL
POSTGRES_USER=CHANGE_ME_POSTGRES_USER
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=CHANGE_ME_POSTGRES_DB

# App security
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
ADMIN_JWT_SECRET=CHANGE_ME_LONG_RANDOM_ADMIN_SECRET

# Telegram admin control
TELEGRAM_BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN
NOTIFICATION_BOT_TOKEN=
ADMIN_CHAT_ID=CHANGE_ME_NUMERIC_CHAT_ID

# Telegram admin support bot
ADMIN_SUPPORT_BOT_TOKEN=CHANGE_ME_ADMIN_SUPPORT_BOT_TOKEN
ADMIN_SUPPORT_CHAT_ID=-1003912107958
ADMIN_SUPPORT_DEFAULT_LANGUAGE=ru
ADMIN_SUPPORT_FALLBACK_LANGUAGE=en

# Resend for notification-bot-service
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
MAILER_FROM_EMAIL=support@swimvpn.pro
MAILER_FROM_NAME=SWIMVPN+ Support

# Business defaults
DEFAULT_CURRENCY=RUB

# Note:
# Dockploy currently uses host port 3000; this compose does not publish 3000.
