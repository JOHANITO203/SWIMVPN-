# SWIMVPN+ production environment
# Copy to .env and set real values before deploy

NODE_ENV=production
LOG_LEVEL=info

# Domain / reverse proxy is managed by Dockploy global Traefik
# (No embedded Traefik in this compose)

# PostgreSQL
POSTGRES_USER=CHANGE_ME_POSTGRES_USER
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=CHANGE_ME_POSTGRES_DB
# Required by Prisma/backend services. Keep credentials aligned with POSTGRES_* above.
DATABASE_URL=postgresql://CHANGE_ME_POSTGRES_USER:CHANGE_ME_STRONG_PASSWORD@db:5432/CHANGE_ME_POSTGRES_DB?schema=public

# Seed policy
# Production seed creates only missing reference plans/servers.
# Demo/starter VPN inventory is disabled unless explicitly enabled.
SEED_DEMO_DATA=false

# App security
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
ADMIN_JWT_SECRET=CHANGE_ME_LONG_RANDOM_ADMIN_SECRET

# Admin bootstrap
# No default database admin is created by the production seed.
# Create the first Admin row through a controlled ops step with a bcrypt password_hash.
# Telegram admin operations must use explicit ADMIN_USER_IDS.

# Telegram admin control
TELEGRAM_BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN
NOTIFICATION_BOT_TOKEN=
ADMIN_CHAT_ID=CHANGE_ME_NUMERIC_CHAT_ID
ADMIN_USER_IDS=
PAYMENT_BOT_USERNAME=CHANGE_ME_PAYMENT_BOT_USERNAME
PAYMENT_REVIEW_CHAT_ID=
MANUAL_CARD_NUMBER=

# Telegram admin support bot
ADMIN_SUPPORT_BOT_TOKEN=CHANGE_ME_ADMIN_SUPPORT_BOT_TOKEN
ADMIN_SUPPORT_CHAT_ID=-1003912107958
ADMIN_SUPPORT_REPORT_CHAT_ID=
ADMIN_SUPPORT_DEFAULT_LANGUAGE=ru
ADMIN_SUPPORT_FALLBACK_LANGUAGE=en

# Resend for notification-bot-service
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
MAILER_FROM_EMAIL=support@swimvpn.pro
MAILER_FROM_NAME=SWIMVPN+ Support

# Business defaults
DEFAULT_CURRENCY=RUB

# Crypto Pay API
CRYPTO_PAY_API_TOKEN=
CRYPTO_PAY_API_BASE_URL=https://pay.crypt.bot/api
CRYPTO_PAY_ACCEPTED_ASSETS=USDT,TON,BTC,ETH,TRX,LTC,BNB,USDC
CRYPTO_PAY_INVOICE_EXPIRES_IN=1800

# SwimPay manual-confirmation checkout
SWIMPAY_API_BASE_URL=https://staging.swimpay.pro
SWIMPAY_SECRET_KEY=
SWIMPAY_WEBHOOK_SECRET=
SWIMPAY_WEBHOOK_URL=https://api.swimvpn.pro/api/v1/payments/swimpay/webhook
SWIMPAY_RETURN_BASE_URL=https://api.swimvpn.pro/api/v1/payments/swimpay/return

# Note:
# Dockploy currently uses host port 3000; this compose does not publish 3000.
