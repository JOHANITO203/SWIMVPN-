# SWIMVPN+ environment (source-of-truth aligned)

NODE_ENV=production
LOG_LEVEL=info

# Database
POSTGRES_USER=swim_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=swimvpn_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://swim_user:change_this_password@db:5432/swimvpn_db?schema=public

# Gateway
GATEWAY_PORT=3000

# Inter-service discovery (Docker service names)
CUSTOMER_SERVICE_HOST=customer-order-service
INVENTORY_SERVICE_HOST=inventory-delivery-service
ADMIN_SERVICE_HOST=admin-control-service
VPN_CONFIG_SERVICE_HOST=vpn-config-engine-service
STORE_SERVICE_HOST=store-engine-service

# Security
JWT_SECRET=change_this_jwt_secret

# Admin Telegram control channel
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
ADMIN_CHAT_ID=your_admin_chat_id

# Business defaults
DEFAULT_CURRENCY=RUB

# Deferred in MVP (documented only; not active runtime surface)
# PSP integration is postponed.
# PAYMENT_PROVIDER_SHOP_ID=
# PAYMENT_PROVIDER_SECRET_KEY=
